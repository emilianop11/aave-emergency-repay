# Arbitrum RPC used for fork tests and live scripts.
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Deployment wallet. Use a dedicated deployer; never commit this file.
DEPLOYER_PRIVATE_KEY=

# Disposable keeper wallet used only to call checkAndRepay().
KEEPER_PRIVATE_KEY=
KEEPER_ADDRESS=

# Immutable EOA that owns the Aave aWETH collateral and variable USDC debt.
# This address also receives all WETH/USDC dust swept by the emergency contract.
POSITION_OWNER_ADDRESS=

# Populated after deployment.
REPAYER_ADDRESS=

# Immutable deployment parameters for Arbitrum One WETH/native-USDC.
# Aave's current oracle is resolved dynamically through the Aave Pool addresses provider.
# The canonical Uniswap V3 WETH/native-USDC 0.05% pool and fee are hardcoded in scripts/addresses.ts.
# Must be between 1 and 500.
MAX_SLIPPAGE_BPS=300
TRIGGER_HF=1.10
# Must be >0 and <=10 native USDC.
USDC_REPAY_BUFFER=1

# Optional keeper gas limit.
KEEPER_GAS_LIMIT=2500000

# Optional calldata helper input. Use "max" or a decimal aWETH amount, e.g. 5.25.
AWETH_APPROVAL_AMOUNT=max

# Fork smoke test:
# ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc npm run test:fork
