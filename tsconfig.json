{
  "compilerOptions": {
    "lib": [
      "es2023"
    ],
    "module": "node20",
    "moduleResolution": "node16",
    "target": "es2023",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": [
      "node",
      "mocha"
    ],
    "verbatimModuleSyntax": true
  },
  "include": [
    "hardhat.config.ts",
    "scripts/**/*.ts",
    "test/**/*.ts",
    "ignition/**/*.ts",
    "types/**/*.ts"
  ]
}
